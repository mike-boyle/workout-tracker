rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Secure user metadata settings documents
    match /users/{userId}/metadata/{settingsId} {
      allow read, delete: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null && request.auth.uid == userId;
    }

    // Secure user cycle documents and nested subcollections
    match /users/{userId}/cycles/{cycleId} {
      allow read, delete: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null && request.auth.uid == userId;

      // Secure individual workout logs in the subcollection
      match /logs/{logId} {
        allow read, delete: if request.auth != null && request.auth.uid == userId;
        allow create, update: if request.auth != null && request.auth.uid == userId
          // Prevent unreasonably long comments (max 2000 characters)
          && (request.resource.data.comments == null || request.resource.data.comments.size() < 2000);
      }
    }
  }
}